{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/setup.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash scripts/post-edit-check.sh",
        "matcher": "Edit"
      },
      {
        "type": "command",
        "command": "bash scripts/post-edit-check.sh",
        "matcher": "Write"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash scripts/pre-commit-check.sh",
        "matcher": "Bash"
      }
    ]
  }
}
