#!/usr/bin/env bash
# Git pre-commit hook for {{project-name}}
# Install with: ./scripts/install-hooks.sh

set -euo pipefail

# Bail out early if Cargo.toml isn't parseable (e.g. template placeholders)
if ! cargo metadata --format-version=1 --no-deps &>/dev/null; then
    echo "Cargo.toml not parseable — skipping cargo checks."
    exit 0
fi

echo "Running pre-commit checks..."

# 1. Formatting check (fast, catches style issues)
echo "  Checking formatting..."
cargo fmt -- --check || {
    echo "ERROR: Code is not formatted. Run 'cargo fmt' and try again."
    exit 1
}

# 2. Linting (catches bugs, enforces project conventions)
echo "  Running clippy..."
cargo clippy -- -D warnings || {
    echo "ERROR: Clippy found warnings. Fix them and try again."
    exit 1
}

# 3. Tests (catches regressions)
echo "  Running tests..."
cargo nextest run --quiet || {
    echo "ERROR: Tests failed. Fix them and try again."
    exit 1
}

# 4. Dependency audit (catches license/advisory issues)
if command -v cargo-deny &> /dev/null; then
    echo "  Auditing dependencies..."
    cargo deny check || {
        echo "ERROR: Dependency audit failed. Fix issues and try again."
        exit 1
    }
else
    echo "  Skipping dependency audit (cargo-deny not installed)"
fi

# 5. Workflow linting (catches CI config and security issues)
WORKFLOW_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '.github/workflows/*.yml' '.github/workflows/*.yaml' || true)
if [ -n "$WORKFLOW_FILES" ]; then
    if command -v actionlint &> /dev/null; then
        echo "  Running actionlint..."
        echo "$WORKFLOW_FILES" | xargs actionlint || {
            echo "ERROR: actionlint found issues. Fix them and try again."
            exit 1
        }
    else
        echo "  Skipping actionlint (not installed)"
    fi
    if command -v zizmor &> /dev/null; then
        echo "  Running zizmor..."
        echo "$WORKFLOW_FILES" | xargs zizmor || {
            echo "ERROR: zizmor found security issues. Fix them and try again."
            exit 1
        }
    else
        echo "  Skipping zizmor (not installed)"
    fi
fi

echo "All pre-commit checks passed!"
